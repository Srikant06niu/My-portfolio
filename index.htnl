<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Srikant Portfolio</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Poppins,sans-serif;
}

body{
background:linear-gradient(
135deg,
#0f0c29,
#302b63,
#24243e
);

color:white;

min-height:100vh;
display:flex;
justify-content:center;
align-items:center;
padding:20px;
}

.card{

width:850px;

background:rgba(255,255,255,.08);

backdrop-filter:blur(18px);

padding:50px;

border-radius:35px;

box-shadow:
0 0 30px rgba(255,255,255,.08);

text-align:center;
}

.profile{

width:130px;
height:130px;

margin:auto;

border-radius:50%;

background:
linear-gradient(
45deg,
#ff6ec4,
#7873f5
);

display:flex;
justify-content:center;
align-items:center;

font-size:45px;
font-weight:bold;

margin-bottom:25px;
}

h1{
font-size:60px;
margin-bottom:10px;
}

span{
background:linear-gradient(
45deg,
#ff6ec4,
#7873f5
);

-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
}

p{

color:#d6d6d6;

margin-top:10px;

line-height:1.7;
}

.skills{

display:flex;

justify-content:center;

gap:12px;

flex-wrap:wrap;

margin-top:30px;
}

.skill{

padding:12px 18px;

border-radius:30px;

background:rgba(255,255,255,.08);

border:1px solid rgba(255,255,255,.1);

transition:.5s;
}

.skill:hover{

transform:translateY(-8px);

box-shadow:
0 0 20px #ff6ec4;

}

.btn{

display:inline-block;

margin-top:35px;

padding:14px 30px;

border-radius:30px;

text-decoration:none;

background:
linear-gradient(
45deg,
#ff6ec4,
#7873f5
);

color:white;

font-weight:bold;

transition:.5s;

}

.btn:hover{

transform:scale(1.08);

}

</style>

</head>

<body>

<div class="card">

<div class="profile">
S
</div>

<h1>Hi, I'm <span>Srikant</span></h1>

<p>
🚀 BCA Student | Learning Java & Web Development
</p>

<div class="skills">

<div class="skill">Java</div>

<div class="skill">HTML</div>

<div class="skill">MS Excel</div>

<div class="skill">Communication</div>

</div>

<a href="https://www.linkedin.com/in/srikant-kr-sjs-039765391" class="btn">
LinkedIn
</a>

</div>

</body>
</html>
